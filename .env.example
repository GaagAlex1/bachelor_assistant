# Environment Configuration for Document Vector Search API

# API Configuration
API_PORT=8000

# Nginx Configuration (if using with-nginx profile)
NGINX_PORT=80

# Embedding Model Configuration
# Options: mock (for testing), sentence-transformers/all-MiniLM-L6-v2, etc.
EMBEDDING_MODEL=mock

# Chunking Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Vector Store Configuration
# Set to true for FAISS (requires more memory, faster search)
USE_FAISS=false
VECTOR_DIMENSION=384

# Redis Configuration (if using with-redis profile)
REDIS_PORT=6379
